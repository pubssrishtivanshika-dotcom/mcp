# ──────────────────────────────────────────────────────────────────────────────
# prod.env — PRODUCTION deploy profile
#
# Selected by setting ENV_FILE=prod.env in the Railway "production" environment's
# variables (and the Docker image default — see Dockerfile). Committed values are
# NON-SECRET config + placeholders; the real secrets (DJANGO_SECRET_KEY,
# CREDENTIALS_ENCRYPTION_KEYS, DATABASE_URL) MUST be set in Railway's dashboard,
# which WINS over these placeholders (load_dotenv does not override OS env vars).
#
# `{publisher_id}` is a literal template token — leave it intact.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required secrets (set the REAL values in Railway's dashboard, not here) ────
# REQUIRED SECRET. Override in Railway → Variables. NEVER commit the real key.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# REQUIRED SECRET. Dedicated Fernet key(s), comma-separated for rotation. Override in Railway.
CREDENTIALS_ENCRYPTION_KEYS=change-me-to-a-fernet-key
# REQUIRED SECRET. Postgres URL. Override in Railway (often a ${{Postgres.DATABASE_URL}} reference).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── Upstream Publive APIs ─────────────────────────────────────────────────────
# Pointed at the BETA upstream for now — the credentials in use are beta-issued, so
# validating/serving against the prod CDS/CMS returns HTTP 400 (key authenticates but
# the publisher doesn't exist in prod). Switch back to the cds/cms.thepublive.com
# hosts below once prod-issued credentials are in use.
CDS_BASE_URL=https://cds-beta.thepublive.com/publisher/{publisher_id}
CMS_BASE_URL=https://cms-beta.thepublive.com/publisher/{publisher_id}
# Prod upstream (restore when using prod credentials):
# CDS_BASE_URL=https://cds.thepublive.com/publisher/{publisher_id}
# CMS_BASE_URL=https://cms.thepublive.com/publisher/{publisher_id}

# ── Hosts / URLs ──────────────────────────────────────────────────────────────
# REQUIRED. Comma-separated real hostnames (Railway's public domain is appended
# automatically via RAILWAY_PUBLIC_DOMAIN when present).
DJANGO_ALLOWED_HOSTS=mcp.thepublive.com,mcp-production-76b6.up.railway.app
# Public HTTPS base URL of this deploy. MUST match the exact origin clients connect
# through — it is advertised as the OAuth `issuer` and `registration_endpoint`, so a
# mismatch breaks Dynamic Client Registration (mcp_registration_failed). Using the
# Railway host for now; switch to https://mcp.thepublive.com once its DNS/custom
# domain points at this service.
BASE_URL=https://mcp-production-76b6.up.railway.app

# ── Security toggles (explicit; no environment-name conditional) ──────────────
DEBUG=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# ── Logging levels (per app) ──────────────────────────────────────────────────
ROOT_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
MCP_LOG_LEVEL=INFO
AUTH_LOG_LEVEL=INFO

# ── Monitoring (New Relic) ────────────────────────────────────────────────────
# Set the REAL license key in Railway → Variables (it must be an OS env var so the
# agent and entrypoint.sh see it before Django loads). app_name defaults to
# "Publive MCP" from newrelic.ini; override here to distinguish the prod app.
# NEW_RELIC_LICENSE_KEY=set-in-railway
NEW_RELIC_APP_NAME=Publive MCP (prod)

# ── Misc ──────────────────────────────────────────────────────────────────────
SERVER_VERSION=1.0.0
