# ──────────────────────────────────────────────────────────────────────────────
# prod.env — AWS FARGATE deploy profile (PRODUCTION)
#
# Runs on AWS ECS Fargate (see aws/task-definition.json, aws/README.md) with the
# BETA upstream CDS/CMS. Selected by ENV_FILE=prod.env — the Dockerfile default and
# the task definition's `environment`. Committed values are NON-SECRET config +
# placeholders; the real secrets (DJANGO_SECRET_KEY, CREDENTIALS_ENCRYPTION_KEYS,
# DATABASE_URL) are injected at runtime from AWS Secrets Manager, which WINS over
# these placeholders (load_dotenv does not override OS env vars).
#
# Hosts/URL are kept on the Railway domain for now, until DNS is cut over to the AWS
# ALB. NOTE: the task definition's `environment` block also sets DJANGO_ALLOWED_HOSTS
# and BASE_URL as real OS env vars, which override the values here — update
# aws/task-definition.json too when cutting the domain over.
#
# `{publisher_id}` is a literal template token — leave it intact.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required secrets (injected at runtime from AWS Secrets Manager, not here) ──
# REQUIRED SECRET. NEVER commit the real key.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# REQUIRED SECRET. Dedicated Fernet key(s), comma-separated for rotation.
CREDENTIALS_ENCRYPTION_KEYS=change-me-to-a-fernet-key
# REQUIRED SECRET. Postgres URL (e.g. the Supabase session-pooler string).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── Upstream Publive APIs (BETA) ──────────────────────────────────────────────
# Pointed at the BETA upstream — the credentials in use are beta-issued, so validating
# against the prod CDS/CMS returns HTTP 400 (key authenticates but the publisher doesn't
# exist in prod). Switch to the cds/cms.thepublive.com hosts below once prod-issued
# credentials are in use.
CDS_BASE_URL=https://cds-beta.thepublive.com/publisher/{publisher_id}
CMS_BASE_URL=https://cms-beta.thepublive.com/publisher/{publisher_id}
# Prod upstream (restore when using prod credentials):
# CDS_BASE_URL=https://cds.thepublive.com/publisher/{publisher_id}
# CMS_BASE_URL=https://cms.thepublive.com/publisher/{publisher_id}

# ── Hosts / URLs (Railway host retained until AWS DNS cutover) ─────────────────
DJANGO_ALLOWED_HOSTS=mcp.thepublive.com,mcp-production-76b6.up.railway.app
BASE_URL=https://mcp-production-76b6.up.railway.app

# ── AWS Fargate runtime ───────────────────────────────────────────────────────
# gunicorn binds 0.0.0.0:$PORT (entrypoint.sh); the Fargate task maps containerPort 8000.
PORT=8000
AWS_REGION=ap-south-1

# ── Security toggles (explicit; no environment-name conditional) ──────────────
DEBUG=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# ── Logging levels (per app) ──────────────────────────────────────────────────
ROOT_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
MCP_LOG_LEVEL=INFO
AUTH_LOG_LEVEL=INFO

# ── Monitoring (New Relic) ────────────────────────────────────────────────────
# On Fargate the license key is injected from Secrets Manager (publive/newrelic-key),
# which overrides the value below.
NEW_RELIC_LICENSE_KEY=F9F9545B50F093B35DBEF530089CFCDACB9D5C3EE73477272C0431CE3B375362
NEW_RELIC_APP_NAME=Publive MCP (prod)

# ── Misc ──────────────────────────────────────────────────────────────────────
SERVER_VERSION=1.0.0
