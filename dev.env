# ──────────────────────────────────────────────────────────────────────────────
# dev.env — LOCAL DEVELOPMENT profile
#
# Loaded by publive_mcp/settings.py when ENV_FILE is unset (the default) or set to
# "dev.env". `python manage.py runserver` uses this. Switch profiles with zero code
# edits by exporting ENV_FILE=beta.env or ENV_FILE=prod.env.
#
# `{publisher_id}` in the CDS/CMS URLs is a literal template token — settings.py
# leaves it intact and the HTTP clients .format() it per request. Do not replace it.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required secrets ──────────────────────────────────────────────────────────
# REQUIRED. Django cryptographic signing key. A placeholder is fine for local dev.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# REQUIRED (recommended). Fernet key(s) for encrypting Publive credentials at rest,
# comma-separated for rotation (first encrypts, all decrypt). If left blank, a key is
# derived from DJANGO_SECRET_KEY — acceptable locally, NOT for beta/prod.
CREDENTIALS_ENCRYPTION_KEYS=

# REQUIRED. Database connection URL. Local dev uses on-disk SQLite (no Postgres needed).
DATABASE_URL=sqlite:///db.sqlite3

# ── Upstream Publive APIs ─────────────────────────────────────────────────────
# Local dev points at the beta upstream hosts.
CDS_BASE_URL=https://cds-beta.thepublive.com/publisher/{publisher_id}
CMS_BASE_URL=https://cms-beta.thepublive.com/publisher/{publisher_id}

# ── Hosts / URLs ──────────────────────────────────────────────────────────────
# Comma-separated allowed hosts. Empty → "*" (convenient for local dev only).
DJANGO_ALLOWED_HOSTS=
# Public base URL of this server (used for CSRF_TRUSTED_ORIGINS).
BASE_URL=http://localhost:8000

# ── Security toggles (explicit per profile; no environment-name conditional) ──
# DEBUG on locally. Secure cookies OFF because local dev is plain HTTP.
DEBUG=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── OAuth ─────────────────────────────────────────────────────────────────────
# Access-token lifetime in seconds (clients refresh via refresh_token). Default 3600 (1h).
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# ── Logging levels (per app) ──────────────────────────────────────────────────
ROOT_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
MCP_LOG_LEVEL=DEBUG
AUTH_LOG_LEVEL=INFO

# ── Monitoring (New Relic) ────────────────────────────────────────────────────
# Off locally: entrypoint.sh only starts the agent when NEW_RELIC_LICENSE_KEY is a
# real OS env var (injected via Railway in beta/prod). Leave blank for local dev.
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME=Publive MCP (dev)

# ── Misc ──────────────────────────────────────────────────────────────────────
# Version advertised in MCP initialize serverInfo and health probes.
SERVER_VERSION=1.0.0
