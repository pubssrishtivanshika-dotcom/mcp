# ──────────────────────────────────────────────────────────────────────────────
# dev.env — RAILWAY deploy profile (default ENV_FILE)
#
# Holds the full Railway deployment config — the settings that previously lived in
# prod.env, back when production ran on Railway. Points at the BETA upstream CDS/CMS.
# Selected by the default ENV_FILE=dev.env in settings.py (or ENV_FILE=dev.env in a
# Railway environment's dashboard variables).
#
# Real secrets (DJANGO_SECRET_KEY, CREDENTIALS_ENCRYPTION_KEYS, DATABASE_URL) are
# injected via Railway's dashboard and WIN over these placeholders (load_dotenv does
# not override OS env vars). `{publisher_id}` is a literal template token — leave intact.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required secrets (set the REAL values in Railway's dashboard, not here) ────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
CREDENTIALS_ENCRYPTION_KEYS=change-me-to-a-fernet-key
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── Upstream Publive APIs (BETA) ──────────────────────────────────────────────
CDS_BASE_URL=https://cds-beta.thepublive.com/publisher/{publisher_id}
CMS_BASE_URL=https://cms-beta.thepublive.com/publisher/{publisher_id}

# ── Hosts / URLs (Railway) ────────────────────────────────────────────────────
DJANGO_ALLOWED_HOSTS=mcp-production-76b6.up.railway.app
BASE_URL=https://mcp-production-76b6.up.railway.app

# ── Security toggles (explicit; no environment-name conditional) ──────────────
DEBUG=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# ── Logging levels (per app) ──────────────────────────────────────────────────
ROOT_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
MCP_LOG_LEVEL=INFO
AUTH_LOG_LEVEL=INFO

# ── Monitoring (New Relic) ────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=F9F9545B50F093B35DBEF530089CFCDACB9D5C3EE73477272C0431CE3B375362
NEW_RELIC_APP_NAME=Publive MCP (DEV)

# ── Misc ──────────────────────────────────────────────────────────────────────
SERVER_VERSION=1.0.0
