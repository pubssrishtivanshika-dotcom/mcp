# ──────────────────────────────────────────────────────────────────────────────
# beta.env — AWS deploy profile (BETA / staging)
#
# Runs on AWS with the BETA upstream CDS/CMS. Selected by ENV_FILE=beta.env in the
# AWS environment (ECS task definition `environment`, or the container's env).
#
# The committed values are NON-SECRET config + placeholders; the real secrets
# (DJANGO_SECRET_KEY, CREDENTIALS_ENCRYPTION_KEYS, DATABASE_URL) are injected at
# runtime from AWS Secrets Manager, which WINS over these placeholders because
# load_dotenv does not override variables already present in the OS environment.
#
# Hosts/URL are kept on the Railway domain for now, until DNS is cut over to the AWS
# load balancer. `{publisher_id}` is a literal template token — leave it intact.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required secrets (injected at runtime from AWS Secrets Manager, not here) ──
# REQUIRED SECRET.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# REQUIRED SECRET. Dedicated Fernet key(s), comma-separated for rotation.
CREDENTIALS_ENCRYPTION_KEYS=change-me-to-a-fernet-key
# REQUIRED SECRET. Postgres URL (e.g. the Supabase session-pooler string).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── Upstream Publive APIs (BETA) ──────────────────────────────────────────────
CDS_BASE_URL=https://cds-beta.thepublive.com/publisher/{publisher_id}
CMS_BASE_URL=https://cms-beta.thepublive.com/publisher/{publisher_id}

# ── Hosts / URLs (Railway host retained until AWS DNS cutover) ─────────────────
DJANGO_ALLOWED_HOSTS=mcp-production-76b6.up.railway.app
BASE_URL=https://mcp-production-76b6.up.railway.app

# ── AWS runtime ───────────────────────────────────────────────────────────────
# gunicorn binds 0.0.0.0:$PORT (entrypoint.sh); the ECS task maps containerPort 8000.
PORT=8000
AWS_REGION=ap-south-1

# ── Security toggles (explicit; no environment-name conditional) ──────────────
DEBUG=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600

# ── Logging levels (per app) ──────────────────────────────────────────────────
ROOT_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
# DEBUG on beta for richer diagnostics during staging.
MCP_LOG_LEVEL=DEBUG
AUTH_LOG_LEVEL=INFO

# ── Monitoring (New Relic) ────────────────────────────────────────────────────
# License key injected at runtime from AWS Secrets Manager (publive/newrelic-key).
# NEW_RELIC_LICENSE_KEY=set-in-secrets-manager
NEW_RELIC_APP_NAME=Publive MCP (beta)

# ── Misc ──────────────────────────────────────────────────────────────────────
SERVER_VERSION=1.0.0
